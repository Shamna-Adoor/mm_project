{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SegmentMap",
  "description": "Player-consumed segment metadata for a single video.",
  "type": "object",
  "required": ["video_id", "duration_seconds", "generated_at", "segments"],
  "properties": {
    "video_id": {
      "type": "string",
      "description": "Stable identifier derived from the video filename or YouTube ID."
    },
    "duration_seconds": {
      "type": "number",
      "minimum": 0
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when this file was produced."
    },
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["start", "end", "label", "confidence", "skip_recommended", "reason", "signals_used"],
        "properties": {
          "start": {
            "type": "number",
            "minimum": 0,
            "description": "Segment start in seconds."
          },
          "end": {
            "type": "number",
            "minimum": 0,
            "description": "Segment end in seconds."
          },
          "label": {
            "type": "string",
            "enum": ["intro", "main_content", "sponsor", "outro", "dead_air"]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "skip_recommended": {
            "type": "boolean"
          },
          "reason": {
            "type": "string",
            "description": "Human-readable explanation of why this label was assigned."
          },
          "signals_used": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Names of signals that contributed to this classification."
          }
        }
      }
    },
    "chapters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["start", "end", "title"],
        "properties": {
          "start": { "type": "number", "minimum": 0 },
          "end": { "type": "number", "minimum": 0 },
          "title": { "type": "string" }
        }
      }
    },
    "source": {
      "type": "object",
      "properties": {
        "source_url": { "type": ["string", "null"] },
        "webpage_url": { "type": ["string", "null"] },
        "playback_url": { "type": ["string", "null"] },
        "title": { "type": ["string", "null"] },
        "extractor": { "type": ["string", "null"] },
        "source_id": { "type": ["string", "null"] },
        "is_live": { "type": "boolean" },
        "is_stream": { "type": "boolean" },
        "mime_type": { "type": ["string", "null"] }
      }
    }
  }
}
